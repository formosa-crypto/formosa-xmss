name: Check EasyCrypt Proofs

on:
  push:
    branches:
      - '**'
  pull_request:
    branches:
      - main

jobs:
  check_proofs:
    runs-on: ubuntu-latest

    steps:
      - name: Check out code
        uses: actions/checkout@v4

      - name: Build docker image
        run: docker build -t jasmin-xmss .

      - name: Check single/multi tree proof
        run: docker run --rm jasmin-xmss make -C proof/ check_xmss_xmssmt_proof

      - name: Check correctness proofs
        run: docker run --rm jasmin-xmss make -C proof/ check_correctness_proof
