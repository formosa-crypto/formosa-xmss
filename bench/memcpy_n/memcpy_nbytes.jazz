param int XMSS_N = 32;

fn _memcpy_nbyes(reg ptr u8[XMSS_N] out in) -> reg ptr u8[XMSS_N] {
    out[u64 0] = in.[u64 0];
    out[u64 1] = in.[u64 1 * 8];
    out[u64 2] = in.[u64 2 * 8];
    out[u64 3] = in.[u64 3 * 8];
    return out;
}

export 
fn memcpy_nbyes(reg ptr u8[XMSS_N] out in) -> reg ptr u8[XMSS_N] {
    out = _memcpy_nbyes(out, in);
    return out;
}
